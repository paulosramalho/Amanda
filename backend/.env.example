PORT=3000
NODE_ENV=production
DATABASE_URL=
JWT_SECRET=

# Security for manual/cron job execution endpoint (/jobs/ads-collection/run)
JOB_RUNNER_API_KEY=

# Scheduler (UTC) - default 15:00 UTC = 12:00 UTC-3
ADS_COLLECTION_SCHEDULER_ENABLED=false
ADS_COLLECTION_RUN_UTC_HOUR=15
ADS_COLLECTION_RUN_UTC_MINUTE=0
ADS_COLLECTION_SCHEDULER_TICK_MS=60000
ADS_COLLECTION_DAYS_OFFSET=-1

# Google Ads
GOOGLE_ADS_ENABLED=false
GOOGLE_ADS_API_VERSION=v22
GOOGLE_ADS_DEVELOPER_TOKEN=
# Optional fallback when refresh flow is not configured
GOOGLE_ADS_ACCESS_TOKEN=
# Recommended production flow (auto refresh)
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_TOKEN_URL=https://oauth2.googleapis.com/token
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Meta Ads / Instagram Ads
META_ADS_ENABLED=false
META_ADS_API_VERSION=v22.0
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=

# Instagram (conteúdo orgânico — @amandamramalho)
INSTAGRAM_ENABLED=false
INSTAGRAM_API_VERSION=v22.0
INSTAGRAM_ACCESS_TOKEN=                  # Long-lived ~60 dias — gerado pela Amanda no app AMR Ads Connector
INSTAGRAM_USER_ID=17841401371420027      # @amandamramalho — opcional (se vazio, faz discovery via /me/accounts)
INSTAGRAM_TOKEN_ISSUED_DATE=             # YYYY-MM-DD — base do alerta de renovação (45 dias)
INSTAGRAM_NOTIFY_EMAILS=                 # destinatários do e-mail diário (separar por vírgula)
INSTAGRAM_SCHEDULER_ENABLED=false        # liga o ciclo diário automático
INSTAGRAM_RUN_UTC_HOUR=4                 # 04h UTC = 01h BRT

# Publicação Instagram (Fase 1 — agendamento e publicação automática)
IG_PUBLISH_ENABLED=false                 # GATE DE SEGURANÇA: deixar false até validar end-to-end
