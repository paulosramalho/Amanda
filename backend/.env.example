PORT=3000
NODE_ENV=production
DATABASE_URL=
JWT_SECRET=

# Security for manual/cron job execution endpoint (/jobs/ads-collection/run)
JOB_RUNNER_API_KEY=

# Scheduler (UTC) - default 15:00 UTC = 12:00 UTC-3
ADS_COLLECTION_SCHEDULER_ENABLED=false
ADS_COLLECTION_RUN_UTC_HOUR=15
ADS_COLLECTION_RUN_UTC_MINUTE=0
ADS_COLLECTION_SCHEDULER_TICK_MS=60000
ADS_COLLECTION_DAYS_OFFSET=-1

# Google Ads
GOOGLE_ADS_ENABLED=false
GOOGLE_ADS_API_VERSION=v22
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_ACCESS_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# Meta Ads / Instagram Ads
META_ADS_ENABLED=false
META_ADS_API_VERSION=v22.0
META_ADS_ACCESS_TOKEN=
META_ADS_ACCOUNT_ID=
